# ================================
# LLM API 配置
# ================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=your_openai_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# ================================
# GitLab 配置
# ================================
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_token_here
GITLAB_WEBHOOK_SECRET=your_webhook_secret_here

# ================================
# 服务配置
# ================================
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# ================================
# 日志配置
# ================================
LOG_LEVEL=INFO
LOG_FORMAT=json
DEBUG=false

# ================================
# 环境配置
# ================================
ENVIRONMENT=development

# ================================
# 缓存配置
# ================================
CACHE_TTL=3600

# ================================
# 数据库配置 (PostgreSQL)
# ================================
POSTGRES_DB=ai_cicd
POSTGRES_USER=ai_cicd
POSTGRES_PASSWORD=ai_cicd_password
DATABASE_URL=postgresql+asyncpg://ai_cicd:ai_cicd_password@localhost:5432/ai_cicd
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DB_ECHO=false

# ================================
# Redis 配置
# ================================
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ================================
# RabbitMQ 配置
# ================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=ai_cicd

# ================================
# Celery 配置
# ================================
CELERY_BROKER_URL=redis://:redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password@localhost:6379/2

# ================================
# 限流配置
# ================================
MAX_REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_REVIEWS=5

# ================================
# 成本控制
# ================================
DAILY_TOKEN_BUDGET=1000000
ENABLE_COST_TRACKING=true

# ================================
# 功能开关
# ================================
ENABLE_TEST_GENERATION=true
ENABLE_CODE_REVIEW=true
ENABLE_PIPELINE_GENERATION=false
